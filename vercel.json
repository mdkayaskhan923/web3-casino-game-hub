{\n  "build": {\n    "env": {\n      "DATABASE_URL": "your-database-url",\n      "SPIN71_SECRET": "your-secret-key"\n    }\n  },\n  "headers": [\n    {\n      "source": "/*",\n      "headers": [\n        {\n          "key": "Content-Security-Policy",\n          "value": "default-src 'self'; frame-ancestors 'none';"\n        },\n        {\n          "key": "X-Content-Type-Options",\n          "value": "nosniff"\n        },\n        {\n          "key": "X-Frame-Options",\n          "value": "DENY"\n        },\n        {\n          "key": "X-XSS-Protection",\n          "value": "1; mode=block"\n        }\n      ]\n    }\n  ]\n}